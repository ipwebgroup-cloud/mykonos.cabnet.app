title = "Plan Your Stay"
url = "/plan"
layout = "default"
meta_title = "Plan Your Stay | Mykonos Nocturne Luxe"
meta_description = "A refined Mykonos luxury planning form for villa stays, private transfers, sea journeys, hosted arrivals, dining moments, and concierge-led support."

[mykonosPlanBridge]
==
function onStart()
{
    $sourceType = trim((string) request()->query('source_type'));
    if (!in_array($sourceType, ['service', 'experience', 'pathway', 'guest_pathway', 'stay_design'])) {
        $sourceType = '';
    }

    $this['planContext'] = [
        'focus' => trim((string) request()->query('focus')),
        'mode' => trim((string) request()->query('mode')),
        'travel_style' => trim((string) request()->query('travel_style')),
        'occasion_type' => trim((string) request()->query('occasion_type')),
        'group_composition' => trim((string) request()->query('group_composition')),

        'source_type' => $sourceType,
        'source_slug' => trim((string) request()->query('source_slug')),
        'source_title' => trim((string) request()->query('source_title')),
        'source_url' => trim((string) request()->query('source_url')),
    ];
}

==
{% partial 'plan/subhero' %}

<section class="plan-section">
    <div class="container plan-layout v12">
        {% partial 'plan/sidebar' %}
        {% partial 'plan/form' %}
    </div>
</section>
