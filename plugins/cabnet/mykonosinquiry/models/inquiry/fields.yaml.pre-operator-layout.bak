fields:
    request_reference:
        label: Request Reference
        disabled: true
        span: left
    status:
        label: Status
        type: dropdown
        span: right
        options:
            new: New brief
            reviewed: Reviewed
            contacted: Contacted
            proposal_sent: Proposal sent
            awaiting_guest: Awaiting guest
            confirmed: Confirmed
            closed_won: Closed won
            closed_lost: Closed lost
            spam: Spam
            triage: Triage (legacy)
            proposal: Proposal shaping (legacy)
            closed: Closed (legacy)
    full_name:
        label: Full Name
        span: left
    email:
        label: Email
        span: right
    phone:
        label: Phone
        span: left
    country:
        label: Country
        span: right
    guests:
        label: Guests
        type: number
        span: left
    budget:
        label: Budget
        span: right
    arrival_date:
        label: Arrival Date
        type: datepicker
        mode: date
        span: left
    departure_date:
        label: Departure Date
        type: datepicker
        mode: date
        span: right
    details:
        label: Trip Details
        type: textarea
        size: giant

